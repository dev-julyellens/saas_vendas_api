APP_NAME="SaaS Vendas Consignadas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

AUTH_GUARD=api

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=debug

# PostgreSQL (Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=saas_vendas
DB_USERNAME=saas
DB_PASSWORD=secret

# Redis — cache, filas e rate limit
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=array

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

API_RATE_LIMIT=120

# Autenticação e segurança
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_MAX_ATTEMPTS_PER_EMAIL=5
AUTH_EMAIL_ATTEMPT_DECAY=15
AUTH_SINGLE_SESSION=false
AUTH_VALIDATE_SESSION=true

MAIL_MAILER=log
